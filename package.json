{
    "name": "@maustec/mt-runtimes",
    "version": "0.0.1",
    "description": "Runtime packs for Maus-Tec hardware products",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "api",
        "wasm",
        "catalog.json",
        "aliases.json"
    ],
    "scripts": {
        "build": "tsc",
        "test": "vitest run",
        "typecheck": "tsc --noEmit",
        "prepack": "npm run build"
    },
    "keywords": [ "maustec", "runtime", "wasm", "iot" ],
    "author": "Maus-Tec LLC",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/maustec/mt-runtimes.git"
    },
    "engines": {
        "node": ">=20"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "typescript": "^6.0.2",
        "vitest": "^4.1.2"
    }
}
